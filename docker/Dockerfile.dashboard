FROM docker.m.daocloud.io/library/python:3.14-slim

RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    fastapi \
    uvicorn \
    websockets \
    pandas \
    pyecharts \
    python-multipart

WORKDIR /app

# DashboardDeployService uploads generated dashboard app code into /app at runtime.
CMD ["bash", "-lc", "while [ ! -f /app/app.py ]; do sleep 0.2; done; export PYTHONPATH=/app:$PYTHONPATH; exec python3 -m uvicorn app:app --host 0.0.0.0 --port 8000"]
